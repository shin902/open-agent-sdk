    "@modelcontextprotocol/sdk": "^1.26.0",
    "@mozilla/readability": "^0.6.0",
    "ai": "^6.0.70",
    "jsdom": "^28.0.0",
    "turndown": "^7.2.2",
    "uuid": "^11.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
